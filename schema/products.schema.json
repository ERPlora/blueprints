{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erplora.com/schemas/products.schema.json",
  "title": "Product Catalog",
  "description": "Schema for a per-country product catalog. Each file is self-contained with single-language strings (the country's language), local prices, and local currency. No shared catalogs or includes.",
  "type": "object",
  "required": ["version", "business_type", "country", "currency", "categories", "products"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "business_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "country": {
      "type": "string",
      "pattern": "^[a-z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 currency code"
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/Category" },
      "minItems": 1
    },
    "products": {
      "type": "array",
      "items": { "$ref": "#/$defs/Product" },
      "minItems": 1
    }
  },
  "$defs": {
    "Category": {
      "type": "object",
      "required": ["code", "name", "icon", "tax_class_hint", "order"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "icon": { "type": "string" },
        "tax_class_hint": {
          "type": "string",
          "enum": ["super_reduced", "reduced", "standard", "exempt"]
        },
        "order": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Product": {
      "type": "object",
      "required": ["code", "name", "category", "price", "tax_class_hint"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "description": "References a category code in this file"
        },
        "price": {
          "type": "number",
          "minimum": 0
        },
        "tax_class_hint": {
          "type": "string",
          "enum": ["super_reduced", "reduced", "standard", "exempt"]
        },
        "unit": {
          "type": "string",
          "enum": ["unit", "kg", "l", "m", "m2", "hour"],
          "default": "unit"
        },
        "is_weighable": { "type": "boolean" },
        "image": {
          "type": "string",
          "description": "Relative path within data/assets/ (e.g. hospitality/cafe_solo.webp)"
        }
      }
    }
  }
}
